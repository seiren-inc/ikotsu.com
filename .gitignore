# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env.local
.env.*.local

# caches & build tools
.turbo/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.swc

# OS junk
Thumbs.db

# editor
.idea/
.vscode/workspace-settings.json

# temp / swap
*.tmp
*.swp
*.swo
*~
*.iml

# python (monorepo safety)
venv/
env/
.venv/
__pycache__/
*.pyc
